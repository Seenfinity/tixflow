# TixFlow Environment Variables
# Copy this file to .env.local and fill in your values

# CrossMint API (for cNFT minting) - REQUIRED
CROSSMINT_API_KEY=your_crossmint_api_key
CROSSMINT_COLLECTION_ID=your_collection_id

# Google Maps API (for routes/directions) - REQUIRED
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Solana RPC (optional, defaults to Helius devnet)
NEXT_PUBLIC_HELIUS_RPC=https://devnet.helius-rpc.com
